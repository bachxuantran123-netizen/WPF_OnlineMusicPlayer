<Window x:Class="WPF_OnlineMusicPlayer.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Nhập - Music Player" Height="350" Width="300" WindowStartupLocation="CenterScreen" Background="#121212">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="ĐĂNG NHẬP" Foreground="#1DB954" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Tài khoản:" Foreground="White" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,0,15" Padding="5"/>

            <TextBlock Text="Mật khẩu:" Foreground="White" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,0,20" Padding="5"/>

            <Button Command="{Binding LoginCommand}" Content="Đăng Nhập" Height="35" Background="#1DB954" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
            <Button Command="{Binding RegisterCommand}" Content="Đăng Ký Tài Khoản Mới" Height="35" Background="#282828" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>