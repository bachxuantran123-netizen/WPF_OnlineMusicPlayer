<Window x:Class="WPF_OnlineMusicPlayer.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Nhập - Music Player" Height="450" Width="350" 
        WindowStartupLocation="CenterScreen" Background="#121212" ResizeMode="NoResize">

    <Grid>
        <Border Background="#181818" CornerRadius="15" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
            <StackPanel>

                <TextBlock Text="MUSIC PLAYER" Foreground="#1DB954" FontSize="26" FontWeight="Heavy" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Tài khoản" Foreground="#B3B3B3" FontSize="13" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border Background="#282828" CornerRadius="8" Height="40" Margin="0,0,0,20">
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             Background="Transparent" Foreground="White" BorderThickness="0" 
                             VerticalContentAlignment="Center" Padding="10,0" FontSize="14"/>
                </Border>

                <TextBlock Text="Mật khẩu" Foreground="#B3B3B3" FontSize="13" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border Background="#282828" CornerRadius="8" Height="40" Margin="0,0,0,35">
                    <PasswordBox x:Name="txtPassword" Background="Transparent" Foreground="White" 
                                 BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" 
                                 FontSize="14" PasswordChanged="txtPassword_PasswordChanged"/>
                </Border>

                <Button Command="{Binding LoginCommand}" Content="ĐĂNG NHẬP" Height="45" Background="#1DB954" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Margin="0,0,0,15" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="22.5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Command="{Binding RegisterCommand}" Content="ĐĂNG KÝ TÀI KHOẢN MỚI" Height="45" Background="Transparent" Foreground="#B3B3B3" FontWeight="Bold" FontSize="13" BorderThickness="1.5" BorderBrush="#B3B3B3" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="22.5"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>