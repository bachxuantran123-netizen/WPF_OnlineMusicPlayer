<Window x:Class="WPF_OnlineMusicPlayer.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/WPF_Project_Icon.ico"
        Title="Đăng Ký - Music Player" Height="600" Width="400" 
        WindowStartupLocation="CenterScreen" Background="#121212" ResizeMode="NoResize">

    <Grid>
        <Border Background="#181818" CornerRadius="15" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
            <StackPanel>

                <TextBlock Text="TẠO TÀI KHOẢN" Foreground="#1DB954" FontSize="24" FontWeight="Heavy" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Tên đăng nhập" Foreground="#B3B3B3" FontSize="13" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border Background="#282828" CornerRadius="8" Height="40" Margin="0,0,0,15">
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" FontSize="14"/>
                </Border>

                <TextBlock Text="Email" Foreground="#B3B3B3" FontSize="13" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border Background="#282828" CornerRadius="8" Height="40" Margin="0,0,0,15">
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" FontSize="14"/>
                </Border>

                <TextBlock Text="Số điện thoại" Foreground="#B3B3B3" FontSize="13" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border Background="#282828" CornerRadius="8" Height="40" Margin="0,0,0,15">
                    <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" FontSize="14"/>
                </Border>

                <TextBlock Text="Mật khẩu" Foreground="#B3B3B3" FontSize="13" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border Background="#282828" CornerRadius="8" Height="40" Margin="0,0,0,15">
                    <PasswordBox x:Name="txtPassword" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" FontSize="14" PasswordChanged="txtPassword_PasswordChanged"/>
                </Border>

                <TextBlock Text="Xác nhận mật khẩu" Foreground="#B3B3B3" FontSize="13" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border Background="#282828" CornerRadius="8" Height="40" Margin="0,0,0,25">
                    <PasswordBox x:Name="txtConfirmPassword" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" FontSize="14" PasswordChanged="txtConfirmPassword_PasswordChanged"/>
                </Border>

                <Button Command="{Binding RegisterCommand}" Content="ĐĂNG KÝ" Height="45" Background="#1DB954" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Margin="0,0,0,10" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="22.5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Command="{Binding CancelCommand}" Content="QUAY LẠI ĐĂNG NHẬP" Height="45" Background="Transparent" Foreground="#B3B3B3" FontWeight="Bold" FontSize="13" BorderThickness="1.5" BorderBrush="#B3B3B3" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="22.5"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>